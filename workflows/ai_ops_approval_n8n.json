        -460,
        -160
      ]
    },
    {
      "parameters": {
        "jsCode": "const request = $json;\nconst needsReview = request.triage?.requires_human_review === true;\nconst baseUrl = $env.WEBHOOK_URL || 'http://localhost:5678';\nreturn [{\n  json: {\n    request_id: request.id,\n    status: request.status,\n    category: request.triage?.category,\n    priority: request.triage?.priority,\n    confidence: request.triage?.confidence,\n    requires_human_review: needsReview,\n    suggested_action: request.triage?.suggested_action,\n    rationale: request.triage?.rationale,\n    risk_flags: request.triage?.risk_flags || [],\n    next_step: needsReview\n      ? 'Send a POST request to the decision webhook with request_id, decision, reviewer, and notes.'\n      : 'No manual decision is required for this low-risk request.',\n    decision_webhook_path: '/webhook/ai-ops-decision',\n    decision_webhook_example: needsReview ? {\n      request_id: request.id,\n      decision: 'approve',\n      reviewer: 'n8n-reviewer',\n      notes: 'Approved after manual review.'\n    } : null,\n    decision_webhook_url_hint: `${baseUrl}/webhook/ai-ops-decision`\n  }\n}];"
      },
      "id": "76d15f0c-e0ce-4fdf-9aa0-c21365d51722",
      "name": "Prepare Request Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -200,
        -160
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ $json }}",
        "options": {}
      },
