  "name": "AI Ops Approval Workflow",
  "nodes": [
    {
      "parameters": {
        "jsCode": "const expected = String($env.AI_OPS_WEBHOOK_SECRET || '');\nfor (const item of $input.all()) {\n  const provided = String(item.json.headers?.['x-webhook-secret'] || '');\n  const body = item.json.body && typeof item.json.body === 'object' && !Array.isArray(item.json.body)\n    ? { ...item.json.body }\n    : {};\n  const bodyIdempotencyKey = body.idempotency_key;\n  delete body.idempotency_key;\n  item.json.webhook_authorized = expected.length > 0 && provided === expected;\n  item.json.idempotency_key = String(\n    item.json.headers?.['x-idempotency-key'] ||\n    bodyIdempotencyKey ||\n    `n8n-${$execution.id}`\n  );\n  item.json.request_payload = body;\n}\nreturn $input.all();"
      },
