    {
      "parameters": {
        "jsCode": "const request = $json;\nconst needsReview = request.triage?.requires_human_review === true;\nconst baseUrl = ($env.WEBHOOK_URL || 'http://localhost:5678').replace(/\\/+$/, '');\nreturn [{\n  json: {\n    request_id: request.id,\n    status: request.status,\n    category: request.triage?.category,\n    priority: request.triage?.priority,\n    confidence: request.triage?.confidence,\n    requires_human_review: needsReview,\n    suggested_action: request.triage?.suggested_action,\n    rationale: request.triage?.rationale,\n    risk_flags: request.triage?.risk_flags || [],\n    next_step: needsReview\n      ? 'Send a POST request to the decision webhook with request_id, decision, reviewer, and notes.'\n      : 'No manual decision is required for this low-risk request.',\n    decision_webhook_path: '/webhook/ai-ops-decision',\n    decision_webhook_example: needsReview ? {\n      request_id: request.id,\n      decision: 'approve',\n      reviewer: 'n8n-reviewer',\n      notes: 'Approved after manual review.'\n    } : null,\n    decision_webhook_url_hint: `${baseUrl}/webhook/ai-ops-decision`\n  }\n}];"
      },
      "id": "76d15f0c-e0ce-4fdf-9aa0-c21365d51722",
      "name": "Prepare Request Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -200,
        -160
      ]
    },
    {
      "parameters": {
        "jsCode": "const expected = String($env.AI_OPS_WEBHOOK_SECRET || '');\nconst uuidPattern = /^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i;\nfor (const item of $input.all()) {\n  const provided = String(item.json.headers?.['x-webhook-secret'] || '');\n  const body = item.json.body || {};\n  const requestId = body.request_id ?? item.json.request_id;\n  const decision = body.decision ?? item.json.decision;\n  const reviewer = body.reviewer ?? item.json.reviewer;\n  const notes = body.notes ?? item.json.notes ?? '';\n  item.json.webhook_authorized = expected.length > 0 && provided === expected;\n  item.json.decision_payload_valid =\n    typeof requestId === 'string' &&\n    uuidPattern.test(requestId) &&\n    ['approve', 'reject', 'request_changes'].includes(decision) &&\n    typeof reviewer === 'string' &&\n    reviewer.trim().length >= 2 &&\n    reviewer.trim().length <= 120 &&\n    typeof notes === 'string' &&\n    notes.length <= 2000;\n  item.json.webhook_status = item.json.webhook_authorized ? 422 : 401;\n  item.json.webhook_error = item.json.webhook_authorized\n    ? 'Invalid decision payload'\n    : 'Unauthorized webhook request';\n}\nreturn $input.all();"
      },
